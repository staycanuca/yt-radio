# YT Radio Environment Configuration

# ============================================================================
# PHASE 3: PROXY MANAGEMENT
# ============================================================================

# Enable proxy manager (default: false)
# Set to true if experiencing rate limiting from YouTube
PROXY_ENABLED=false

# Proxy scraping interval in milliseconds (default: 1800000 = 30 minutes)
PROXY_SCRAPE_INTERVAL=1800000

# Proxy testing interval in milliseconds (default: 300000 = 5 minutes)
PROXY_TEST_INTERVAL=300000

# Proxy test timeout in milliseconds (default: 5000 = 5 seconds)
PROXY_TEST_TIMEOUT=5000

# Maximum number of proxies to keep in pool (default: 50)
PROXY_MAX_PROXIES=50

# Minimum number of working proxies required (default: 5)
PROXY_MIN_WORKING=5

# ============================================================================
# RADIO CONFIGURATION
# ============================================================================

# HTTP server port (default: 8080)
PORT=8080

# Gopher server port (default: 70)
GOPHER_PORT=70

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Playback backend: auto, native, yt-dlp (default: auto)
PLAYBACK_BACKEND=auto

# Playback client: ANDROID, IOS, WEB, TVHTML5 (default: ANDROID)
PLAYBACK_CLIENT=ANDROID

# Radio bitrate in kbps (default: 192)
RADIO_BITRATE=192

# Radio format: mp3, aac, ogg, opus (default: mp3)
RADIO_FORMAT=mp3

# Radio codec: libmp3lame, aac, libvorbis, libopus (default: libmp3lame)
RADIO_CODEC=libmp3lame

# ICY metadata interval in bytes (default: 16000)
ICY_META_INT=16000

# ============================================================================
# PRESET CONFIGURATION
# ============================================================================

# Active preset name (optional)
YTRADIO_ACTIVE_PRESET=

# Active profile name (optional)
YTRADIO_ACTIVE_PROFILE=

# ============================================================================
# GEOLOCATION
# ============================================================================

# Geolocation for YouTube API (default: US)
# Format: ISO 3166-1 alpha-2 country code
GEOLOCATION=US

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================

# Backend server port (default: 3000)
BACKEND_PORT=3000

# API key for protected endpoints (default: ytradio-admin)
API_KEY=ytradio-admin

# ============================================================================
# NOTES
# ============================================================================

# 1. Copy this file to .env and adjust values as needed
# 2. Proxy manager is disabled by default - enable only if needed
# 3. Free proxies have 20-40% success rate and add 1-3s latency
# 4. For production, consider using paid proxy services
# 5. All intervals are in milliseconds
# 6. Restart radio after changing configuration
